Bootstrap: docker
From: ubuntu:24.04

# FLUXOS C++ — Apptainer recipe (CPU: OpenMP + MPI, dependency container)
#
# This .sif image installs the build dependencies and ships the FLUXOS source
# tree at /opt/fluxos, but it does NOT compile FLUXOS during image build.
# Compilation is a separate, interactive step inside the container shell.
#
# The intended 4-step workflow — matches the in_a_nutshell deck:
#
#   1. Activate Apptainer on the HPC login node:
#        module load apptainer
#   2. Build the .sif image (installs deps, copies source):
#        apptainer build --fakeroot fluxos_cpu.sif \
#                        containers/fluxos_apptainer.def
#   3. Open a shell inside the container:
#        apptainer shell fluxos_cpu.sif
#   4. Compile FLUXOS inside the shell. The .sif root is read-only, so we
#      bind-mount the host repo at /src and redirect the compiled binary
#      into the host's ./bin/ via CMAKE_RUNTIME_OUTPUT_DIRECTORY:
#        apptainer shell --bind $PWD:/src fluxos_cpu.sif
#        # inside the container:
#        cd /src && mkdir -p build && cd build
#        cmake -DMODE_release=ON -DUSE_MPI=ON \
#              -DCMAKE_RUNTIME_OUTPUT_DIRECTORY=/src/bin /opt/fluxos
#        make -j$(nproc)
#      Then run — still inside the shell, from /src:
#        cd /src
#        ./bin/fluxos_mpi Working_example/modset_river_30h.json
#
# For GPU / CUDA builds use fluxos_apptainer_cuda.def instead.

%files
    ../ /opt/fluxos

%post
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y --no-install-recommends \
        build-essential \
        cmake \
        git \
        ca-certificates \
        libarmadillo-dev \
        nlohmann-json3-dev \
        libhdf5-dev \
        libomp-dev \
        libopenmpi-dev \
        openmpi-bin
    rm -rf /var/lib/apt/lists/*

    # Clean any pre-existing host build artefacts that may have been copied in.
    rm -rf /opt/fluxos/build

%environment
    # Left unset by design — OMP_NUM_THREADS is scheduler-controlled at runtime.
    :

%runscript
    # Default run action = open a shell. The user compiles FLUXOS manually in
    # step 4 and then runs the resulting binary from that shell.
    exec /bin/bash "$@"

%labels
    Author      Diogo Costa <diogo.costa@uevora.pt>
    Application FLUXOS
    Version     cpu-mpi-deps-only
    Note        Dependencies + source only; compile FLUXOS inside the shell.

%help
    FLUXOS CPU dependency image (OpenMP + MPI + triangular mesh toolchain).

    Step 3 — enter the container:
        apptainer shell fluxos_cpu.sif

    Step 4 — compile FLUXOS inside the shell. Because the .sif root is
    read-only, compile via a bind-mounted host dir, and redirect the binary
    output into the host's ./bin/:
        apptainer shell --bind $PWD:/src fluxos_cpu.sif
        # inside the container:
        cd /src && mkdir -p build && cd build
        cmake -DMODE_release=ON -DUSE_MPI=ON \
              -DCMAKE_RUNTIME_OUTPUT_DIRECTORY=/src/bin /opt/fluxos
        make -j$(nproc)
        # run — from /src so modset paths resolve correctly
        cd /src && ./bin/fluxos_mpi Working_example/modset_river_30h.json
