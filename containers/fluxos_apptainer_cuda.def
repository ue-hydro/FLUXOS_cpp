Bootstrap: docker
From: nvidia/cuda:12.4.1-devel-ubuntu22.04

# FLUXOS C++ — Apptainer recipe (GPU: CUDA + MPI, dependency container)
#
# Like fluxos_apptainer.def this .sif installs the toolchain and ships the
# source tree — it does NOT compile FLUXOS during image build. Compilation
# is an explicit step-4 action inside the container shell.
#
# The intended 4-step workflow — matches the in_a_nutshell deck:
#
#   1. Activate Apptainer on the HPC login node:
#        module load apptainer
#   2. Build the .sif (CUDA toolchain + deps + source):
#        apptainer build --fakeroot fluxos_cuda.sif \
#                        containers/fluxos_apptainer_cuda.def
#   3. Open a shell inside the container — needs --nv for GPU access:
#        apptainer shell --nv fluxos_cuda.sif
#   4. Compile FLUXOS inside the shell. The .sif root is read-only, so we
#      bind-mount the host repo at /src and redirect the compiled binary
#      into the host's ./bin/ via CMAKE_RUNTIME_OUTPUT_DIRECTORY:
#        apptainer shell --nv --bind $PWD:/src fluxos_cuda.sif
#        # inside the container:
#        cd /src && mkdir -p build && cd build
#        cmake -DMODE_release=ON -DUSE_TRIMESH=ON -DUSE_MPI=ON -DUSE_CUDA=ON \
#              -DCMAKE_RUNTIME_OUTPUT_DIRECTORY=/src/bin /opt/fluxos
#        make -j$(nproc)
#      Then run — still inside the shell, from /src:
#        cd /src
#        ./bin/fluxos_cuda Working_example/modset_river_30h.json
#
# The CUDA 12.4 toolchain ships inside the image; the host only needs a
# compatible NVIDIA driver. Always pass --nv to expose host GPUs + drivers.

%files
    ../ /opt/fluxos

%post
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y --no-install-recommends \
        build-essential \
        cmake \
        git \
        ca-certificates \
        libarmadillo-dev \
        nlohmann-json3-dev \
        libhdf5-dev \
        libomp-dev \
        libopenmpi-dev \
        openmpi-bin
    rm -rf /var/lib/apt/lists/*

    # Clean any pre-existing host build artefacts that may have been copied in.
    rm -rf /opt/fluxos/build

%environment
    export PATH=/usr/local/cuda/bin:${PATH}
    export LD_LIBRARY_PATH=/usr/local/cuda/lib64:${LD_LIBRARY_PATH:-}

%runscript
    # Default = open a shell. The user compiles FLUXOS in step 4 and runs it
    # from that shell. Remember to invoke with --nv to expose the host GPU.
    exec /bin/bash "$@"

%labels
    Author      Diogo Costa <diogo.costa@uevora.pt>
    Application FLUXOS
    Version     cuda-mpi-deps-only
    CUDA        12.4
    Note        Dependencies + source only; compile FLUXOS inside the shell.

%help
    FLUXOS GPU dependency image (CUDA 12.4 + OpenMP + MPI + trimesh toolchain).
    Always invoke with --nv to expose host GPUs. Compile via a bind-mounted
    host dir, and redirect the binary output into the host's ./bin/:
        apptainer shell --nv --bind $PWD:/src fluxos_cuda.sif
        # inside the container:
        cd /src && mkdir -p build && cd build
        cmake -DMODE_release=ON -DUSE_TRIMESH=ON -DUSE_MPI=ON -DUSE_CUDA=ON \
              -DCMAKE_RUNTIME_OUTPUT_DIRECTORY=/src/bin /opt/fluxos
        make -j$(nproc)
        # run — from /src so modset paths resolve correctly
        cd /src && ./bin/fluxos_cuda Working_example/modset_river_30h.json
